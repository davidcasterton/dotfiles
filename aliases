# tmux
function tm () {
    [ -z "$1" ] && name="1" || name=$1
    tmux a -t $name || tmux new -s $name
}
alias tml="tmux list-sessions"

# grep
function greps () {
    [ -z "${3}" ] && len="50" || len="${3}"
    cmd="grep -r -E -o \".{0,$len}$1.{0,$len}\" ${2}"
    echo $cmd
    eval $cmd
}

# git aliases
alias ghash="git rev-parse HEAD"
alias glog="git log --oneline"
alias gp="git pull"
alias gps="gunlock ; git prune; git pull ; gsubprune ; gunlock ; gsubupdate"
alias grevert="gunlock; git reset --hard HEAD && git clean -fd"
# gunlock: removes git lock files — only run if no git operation is in progress
gunlock() {
    test -e .git/index.lock && echo $'REMOVING .git/index.lock' && rm .git/index.lock
    test -e .git/gc.log && echo $'REMOVING .git/gc.log' && rm .git/gc.log
    git remote prune origin
    git prune
}
alias gbdc="git branch -a | grep davidc; git branch -a | grep dcasterton"
alias gpu="git push"
alias gpn='git push --set-upstream origin $(git symbolic-ref --short HEAD)'
alias gs='git status'
alias gd='git diff'
alias gds='git diff --staged'
alias gcm='git commit -m'
alias gca='git commit --amend'
# gclean: force-deletes local branches whose remotes are gone — destructive, use with care
function gclean {
	git fetch -p
	git prune
	rm .git/gc.log -f
	git remote prune origin
	git branch -vv | grep -oP '(?<=\* |  )(\S+?)(?= +\S+ \[origin\S+: gone\].*)' | awk '{print $1}' | xargs git branch -D
    git gc --prune=now
}
# git aliases - submodules
alias gsubpull="echo $'\nSUBMODULE UPDATE:\n' && git submodule update --recursive --remote --force"
alias gsubrevert="echo $'\nSUBMODULE REVERT:\n' && git submodule foreach --recursive 'git reset --hard HEAD && git clean -fd'"
alias gsubprune="echo $'\nSUBMODULE PRUNE:\n' && git submodule foreach --recursive 'git fetch --prune'"
alias gsubclean="echo $'\nSUBMODULE CLEAN:\n' && git submodule foreach --recursive 'git clean -fd'"
alias gsubupdate="echo $'\nSUBMODULE UPDATE:\n' && git submodule update --init --recursive"
# check if a branch has a commit. 1st arg: branch, 2nd arg commit
alias gwhere='f() { git log "$1" --oneline | grep "$2"; }; f'
# check if release branches have a commit
grel() {
  if [ -z "$1" ]; then
    echo "Usage: grel <commit-hash>"
    return 1
  fi
  git branch -r --contains "$1" | grep 'release'
}

# gif
gif() {
    ffmpeg -i "$1" -filter_complex "[0:v] fps=10,scale=w=1080:h=-1,split [a][b];[a] palettegen [p];[b][p] paletteuse" "$2"
}

# merge master branch
mmb() {
    git fetch origin master:master
    git merge master
}

# rebase master branch
rmb() {
    git fetch origin master:master
    git rebase master
}
# rebase master branch interactive
rmbi() {
    git fetch origin master:master
    git rebase -i master
}

# speed up video 2x
speed2x() {
    if [ -z "$1" ]; then
        echo "Usage: speed2x <video-file>"
        return 1
    fi

    input="$1"

    # Extract filename without extension and extension
    filename="${input%.*}"
    extension="${input##*.}"

    # Create output file name
    output="${filename}-2x.${extension}"

    # Run ffmpeg to speed up video
    ffmpeg -i "$input" -filter:v "setpts=0.5*PTS" -filter:a "atempo=2.0" "$output"

    echo "Output written to: $output"
}

speed15x() {
    if [ -z "$1" ]; then
        echo "Usage: speed15x <video-file>"
        return 1
    fi

    input="$1"

    # Extract filename without extension and extension
    filename="${input%.*}"
    extension="${input##*.}"

    # Create output file name
    output="${filename}-1.5x.${extension}"

    # Run ffmpeg to speed up video
    ffmpeg -i "$input" -filter:v "setpts=0.6667*PTS" -filter:a "atempo=1.5" "$output"

    echo "Output written to: $output"
}

# check if a git sha is in a branch
shain() {
    local sha="$1"
    local branch="$2"

    # Validate arguments
    if [[ -z "$sha" || -z "$branch" ]]; then
        echo "Usage: shain <commit_sha> <branch>"
        echo "Example: shain abc1234 main"
        return 1
    fi

    # Run check
    if git merge-base --is-ancestor "$sha" "$branch" 2>/dev/null; then
        echo "yes"
    else
        echo "no"
    fi
}

# Add an "alert" alias for long running commands.  Use like so:
#   sleep 10; alert
alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'

